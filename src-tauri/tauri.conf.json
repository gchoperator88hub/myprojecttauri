{
  "$schema": "https://tauri.app",
  "productName": "MyTauriApp",
  "version": "0.1.0",
  "identifier": "com.mytauri.app",
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "My App",
        "width": 900,
        "height": 600,
        "dragDropEnabled": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"]
  }
}
